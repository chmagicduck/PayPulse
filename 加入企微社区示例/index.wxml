<!--pages/community/index.wxml — 加入社群-->
<view class="page">

  <!-- 顶部视觉区 -->
  <view class="hero">
    <view class="hero-wave"></view>
    <view class="hero-wave hero-wave-2"></view>
    <view class="hero-content">
      <view class="hero-icon-ring">
        <view class="hero-icon-inner">
          <text class="hero-emoji">🏄</text>
        </view>
      </view>
      <text class="hero-title">薪潮摸鱼社</text>
      <text class="hero-subtitle">汇聚天下打工人，共享摸鱼心得</text>
    </view>
  </view>

  <!-- 社群亮点卡片 -->
  <view class="highlights">
    <view class="highlight-item">
      <view class="highlight-icon-wrap hi-blue">
        <text class="highlight-icon">💬</text>
      </view>
      <view class="highlight-text">
        <text class="highlight-title">摸鱼交流</text>
        <text class="highlight-desc">分享日常摸鱼趣事和省力攻略</text>
      </view>
    </view>
    <view class="highlight-item">
      <view class="highlight-icon-wrap hi-green">
        <text class="highlight-icon">🐟</text>
      </view>
      <view class="highlight-text">
        <text class="highlight-title">段位 PK</text>
        <text class="highlight-desc">晒出你的摸鱼等级，看看谁是鱼王</text>
      </view>
    </view>
    <view class="highlight-item">
      <view class="highlight-icon-wrap hi-amber">
        <text class="highlight-icon">🎁</text>
      </view>
      <view class="highlight-text">
        <text class="highlight-title">新功能抢先</text>
        <text class="highlight-desc">第一时间体验新版本和隐藏功能</text>
      </view>
    </view>
    <view class="highlight-item">
      <view class="highlight-icon-wrap hi-purple">
        <text class="highlight-icon">🤝</text>
      </view>
      <view class="highlight-text">
        <text class="highlight-title">需求直通车</text>
        <text class="highlight-desc">你的想法直达开发者，共建打工利器</text>
      </view>
    </view>
  </view>

  <!-- 加入按钮区 -->
  <view class="join-section">
    <view class="join-card">
      <view class="join-card-deco"></view>
      <view class="join-header">
        <text class="join-title">一键加入摸鱼社群</text>
        <text class="join-desc">扫码或点击下方按钮，即刻加入我们</text>
      </view>
      <view class="join-btn-wrap">
        <cell
          url="{{groupUrl}}"
          bind:startmessage="onStartMessage"
          bind:completemessage="onCompleteMessage"
          contactText="立即加入群聊"
          contactTextBlod="{{true}}"
        />
      </view>
      <view class="join-hint-row">
        <text class="join-hint">加入后可在微信「群聊」中找到我们</text>
      </view>
    </view>
  </view>

  <!-- 底部引言 -->
  <view class="community-footer">
    <text class="footer-quote">"一个人摸鱼是偷懒，一群人摸鱼是文化"</text>
  </view>

  <view class="safe-bottom"></view>
</view>
