/* pages/community/index.wxss — 加入社群 */

.page {
  min-height: 100vh;
  background: #F8FAFC;
  display: flex;
  flex-direction: column;
}

/* ===== 顶部视觉区 ===== */
.hero {
  position: relative;
  background: linear-gradient(150deg, #0F4C81, #1E6DB5, #2E8BC0);
  padding: 56rpx 32rpx 72rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
}

.hero-wave {
  position: absolute;
  bottom: -2rpx;
  left: 0;
  right: 0;
  height: 64rpx;
  background: #F8FAFC;
  border-radius: 50% 50% 0 0 / 100% 100% 0 0;
}

.hero-wave-2 {
  bottom: 8rpx;
  height: 48rpx;
  background: rgba(248, 250, 252, 0.3);
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-icon-ring {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  animation: ring-float 3s ease-in-out infinite;
}

.hero-icon-inner {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-emoji {
  font-size: 52rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #FFFFFF;
  letter-spacing: 6rpx;
  display: block;
}

.hero-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  font-weight: 600;
  display: block;
  margin-top: 12rpx;
  letter-spacing: 2rpx;
}

@keyframes ring-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

/* ===== 社群亮点 ===== */
.highlights {
  padding: 24rpx 32rpx 8rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.highlight-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  border: 1rpx solid #F1F5F9;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.highlight-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hi-blue { background: #EFF6FF; }
.hi-green { background: #F0FDF4; }
.hi-amber { background: #FFFBEB; }
.hi-purple { background: #FAF5FF; }

.highlight-icon {
  font-size: 34rpx;
}

.highlight-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
}

.highlight-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #1E293B;
  display: block;
}

.highlight-desc {
  font-size: 22rpx;
  color: #64748B;
  font-weight: 600;
  display: block;
}

/* ===== 加入按钮区 ===== */
.join-section {
  padding: 24rpx 32rpx 16rpx;
}

.join-card {
  position: relative;
  background: linear-gradient(135deg, #0F4C81, #1E6DB5);
  border-radius: 32rpx;
  padding: 40rpx 32rpx 36rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(15, 76, 129, 0.25);
}

.join-card-deco {
  position: absolute;
  top: -40rpx;
  right: -30rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
  filter: blur(30rpx);
}

.join-header {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.join-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #FFFFFF;
  display: block;
  letter-spacing: 2rpx;
}

.join-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.65);
  font-weight: 600;
  display: block;
  margin-top: 8rpx;
}

.join-btn-wrap {
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 8rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.join-hint-row {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
}

.join-hint {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 600;
}

/* ===== 底部引言 ===== */
.community-footer {
  padding: 40rpx 48rpx 16rpx;
  display: flex;
  justify-content: center;
}

.footer-quote {
  font-size: 22rpx;
  color: #94A3B8;
  font-weight: 600;
  font-style: italic;
  text-align: center;
  line-height: 1.6;
}

/* ===== 底部安全区 ===== */
.safe-bottom { height: 80rpx; }
