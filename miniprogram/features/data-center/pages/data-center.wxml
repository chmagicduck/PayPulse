<view class="page-view data-center-page">
  <view class="data-center-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="data-center-nav__content">
      <view class="data-center-nav__back" bind:tap="handleBack">
        <image class="icon-lg" src="{{icons.chevronLeft}}" mode="aspectFit" />
      </view>
      <text class="data-center-nav__title">{{vm.title}}</text>
      <view class="data-center-nav__placeholder"></view>
    </view>
  </view>

  <view class="data-center-main">
    <pp-section-header title="瀛樺偍鎸囨爣" barTone="blue" />

    <view class="storage-grid">
      <view class="storage-card">
        <view class="storage-card__head">
          <view class="storage-card__icon">
            <image class="icon-lg" src="{{icons.hardDrive}}" mode="aspectFit" />
          </view>
          <view class="storage-card__number">
            <text class="storage-card__eyebrow">鏈湴绌洪棿</text>
            <text class="storage-card__value">{{storageUsedText}} <text class="storage-card__unit">MB</text></text>
          </view>
        </view>

        <view class="storage-card__bar-meta">
          <text>鑸鏁版嵁鍗犳瘮</text>
          <text>{{storagePercentText}}</text>
        </view>
        <view class="storage-card__bar">
          <view class="storage-card__bar-fill" style="width: {{(storageUsed / storageCapacity) * 100}}%;"></view>
        </view>
        <view class="storage-card__foot">
          <text>总容量上限 {{vm.storage.capacity}} MB</text>
          <view class="storage-card__secure">
            <image class="icon-xs" src="{{icons.shieldCheck}}" mode="aspectFit" />
            <text>安全加密中</text>
          </view>
        </view>
      </view>

      <view class="sync-card">
        <view class="sync-card__icon">
          <image class="icon-lg" src="{{icons.cloud}}" mode="aspectFit" />
        </view>
        <text class="sync-card__title">浜戠鍚屾涓績</text>
        <text class="sync-card__desc">鍗冲皢寮€鏀捐法璁惧澶氱鑸鍚屾</text>
        <view class="sync-card__tag">
          <text class="sync-card__tag-text">鏁鏈熷緟</text>
        </view>
      </view>
    </view>

    <pp-section-header title="鏍稿績鎿嶄綔" barTone="dark" />

    <view class="action-list">
      <view class="action-item action-item--primary" bind:tap="handleExport">
        <view class="action-item__main">
          <view class="action-item__icon action-item__icon--blue">
            <image class="icon-md" src="{{exportStatus === 'success' ? icons.checkCircle2 : icons.download}}" mode="aspectFit" />
          </view>
          <view class="action-item__copy">
            <text class="action-item__title">{{exportStatus === 'success' ? '瀵煎嚭鎴愬姛' : '瀵煎嚭澶囦唤鏁版嵁'}}</text>
            <text class="action-item__desc">鐢熸垚 JSON 鏍煎紡鑸鏃ュ織鍓湰</text>
          </view>
        </view>
        <view class="action-item__side">
          <text class="action-item__state" wx:if="{{exportStatus === 'exporting'}}">处理中</text>
          <image class="icon-xs" wx:if="{{exportStatus !== 'exporting'}}" src="{{icons.arrowRightLeft}}" mode="aspectFit" />
        </view>
      </view>

      <view class="action-item action-item--danger" bind:tap="openResetModal">
        <view class="action-item__main">
          <view class="action-item__icon action-item__icon--rose">
            <image class="icon-md" src="{{icons.trash2}}" mode="aspectFit" />
          </view>
          <view class="action-item__copy">
            <text class="action-item__title action-item__title--rose">重置所有数据</text>
            <text class="action-item__desc action-item__desc--rose">擦除所有本地缓存与航行记录</text>
          </view>
        </view>
        <view class="action-item__danger-tag">
          <text>鍗遍櫓鎿嶄綔</text>
        </view>
      </view>
    </view>

    <view class="notice-card">
      <image class="icon-sm" src="{{icons.databasePair.staticSrc}}" mode="aspectFit" />
      <text class="notice-card__text">{{vm.notice}}</text>
    </view>
  </view>

  <view class="reset-overlay {{showResetModal ? 'reset-overlay--visible' : ''}}" bind:tap="closeResetModal">
    <view class="reset-sheet {{resetModalVisible ? 'reset-sheet--visible' : ''}}" catch:tap="">
      <view class="reset-sheet__handle"></view>

      <view class="reset-sheet__header">
        <view class="reset-sheet__titles">
          <text class="reset-sheet__title">确定要清空航程吗</text>
          <text class="reset-sheet__subtitle">此操作将永久删除个人配置、任务进度和薪资记录。</text>
        </view>
        <view class="reset-sheet__close {{pressStates.modalClose ? 'reset-sheet__close--pressed' : ''}}" bind:tap="closeResetModal">
          <image class="icon-lg" src="{{icons.x}}" mode="aspectFit" />
        </view>
      </view>

      <view class="reset-sheet__alert">
        <image class="reset-sheet__icon" src="{{icons.alertTriangle}}" mode="aspectFit" />
      </view>

      <view class="reset-sheet__actions">
        <view class="reset-sheet__btn reset-sheet__btn--ghost" bind:tap="closeResetModal">
          <text>鍙栨秷淇濈暀</text>
        </view>
        <view class="reset-sheet__btn reset-sheet__btn--danger {{pressStates.modalConfirm ? 'reset-sheet__btn--danger-pressed' : ''}}" bind:tap="confirmReset">
          <text>纭娓呴櫎</text>
        </view>
      </view>
    </view>
  </view>
</view>
