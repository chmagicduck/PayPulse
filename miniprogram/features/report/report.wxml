<view class="page-view report-page">
  <view class="report-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="report-nav__content">
      <view class="report-nav__brand">
        <view class="report-nav__logo">
          <image class="report-nav__logo-icon" src="{{iconAnimations.chart ? icons.chartPair.animatedSrc : icons.chartPair.staticSrc}}" mode="aspectFit" />
        </view>
        <text class="report-nav__title">数据报告</text>
      </view>

      <view class="report-nav__filter {{pressStates.filter ? 'report-nav__filter--pressed' : ''}}" bind:tap="pressFilter">
        <image class="icon-sm" src="{{icons.filter}}" mode="aspectFit" />
      </view>
    </view>
  </view>

  <view class="report-main">
    <view class="report-section">
      <view class="report-section-head">
        <pp-section-header title="打工成就" barTone="amber" trimBottom="{{true}}" />
      </view>

      <view class="annual-grid">
        <block wx:for="{{annualCards}}" wx:key="key">
          <view class="annual-tide-card annual-tide-card--{{item.tone}} {{pressStates.annualIndex === index ? 'annual-tide-card--pressed' : ''}}" data-index="{{index}}" bind:tap="pressAnnualCard">
            <image class="annual-tide-card__ghost annual-tide-card__ghost--{{item.tone}}" src="{{item.ghostIconSrc}}" mode="aspectFit" />

            <view class="annual-tide-card__info {{activeAnnualInfoKey === item.key ? 'annual-tide-card__info--active' : ''}}" data-key="{{item.key}}" catch:tap="openAnnualInfo">
              <image class="annual-tide-card__info-icon" src="{{icons.info}}" mode="aspectFit" />
            </view>

            <view class="annual-tide-card__body">
              <view class="annual-tide-card__head">
                <view class="annual-tide-card__icon annual-tide-card__icon--{{item.tone}}">
                  <image class="icon-sm" src="{{item.iconSrc}}" mode="aspectFit" />
                </view>
                <text class="annual-tide-card__badge annual-tide-card__badge--{{item.tone}}">{{item.badgeText}}</text>
              </view>

              <view class="annual-tide-card__content">
                <text class="annual-tide-card__title">{{item.title}}</text>
                <text class="annual-tide-card__value annual-tide-card__value--{{item.tone}}">{{item.value}}</text>
                <text class="annual-tide-card__desc">{{item.desc}}</text>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <view class="report-section">
      <view class="report-section-head report-section-head--toolbar">
        <pp-section-header
          title="搞钱趋势"
          subtitle="{{vm.trend.subtitle}}"
          barTone="indigo"
          trimBottom="{{true}}"
        />

        <view class="tab-switch">
          <view
            class="tab-switch__item tab-switch__item--indigo {{activeTab === 'income' ? 'tab-switch__item--active' : ''}} {{pressStates.tabKey === 'income' ? 'tab-switch__item--pressed' : ''}}"
            data-key="income"
            bind:tap="switchTab"
          >
            <text class="tab-switch__text">收入</text>
          </view>
          <view
            class="tab-switch__item tab-switch__item--amber {{activeTab === 'duration' ? 'tab-switch__item--active' : ''}} {{pressStates.tabKey === 'duration' ? 'tab-switch__item--pressed' : ''}}"
            data-key="duration"
            bind:tap="switchTab"
          >
            <text class="tab-switch__text">时长</text>
          </view>
        </view>
      </view>

      <view class="chart-card">
        <scroll-view class="chart-card__scroll" scroll-x enhanced show-scrollbar="false">
          <view class="chart-card__bars">
            <block wx:for="{{vm.trend.bars}}" wx:key="day">
              <view class="chart-bar {{pressStates.chartBarIndex === index ? 'chart-bar--active' : ''}}" data-index="{{index}}" bind:tap="pressChartBar">
                <view class="chart-bar__tip" wx:if="{{pressStates.chartBarIndex === index}}">
                  <text>{{activeTab === 'income' ? item.incomeText : item.durationText}}</text>
                </view>
                <view class="chart-bar__body">
                  <view class="chart-bar__track chart-bar__track--{{activeTab === 'income' ? 'indigo' : 'amber'}}"></view>
                  <view
                    class="chart-bar__fill chart-bar__fill--{{activeTab === 'income' ? 'indigo' : 'amber'}} {{activeTab === 'income' ? (item.isIncomeEmpty ? 'chart-bar__fill--empty' : '') : (item.isDurationEmpty ? 'chart-bar__fill--empty' : '')}}"
                    style="height: {{activeTab === 'income' ? item.incomeHeight : item.durationHeight}};"
                  ></view>
                </view>
                <text class="chart-bar__label">{{item.day}}</text>
              </view>
            </block>
          </view>
        </scroll-view>

        <view class="chart-card__summary">
          <view class="chart-card__summary-copy">
            <view class="chart-card__summary-inline">
              <text class="chart-card__eyebrow">{{vm.trend.summaryLabel}}</text>
              <text class="chart-card__value chart-card__value--{{activeTab === 'income' ? 'indigo' : 'amber'}}">
                {{activeTab === 'income' ? vm.trend.summary.incomeTotal : vm.trend.summary.durationTotal}}
              </text>
              <text class="chart-card__unit">{{activeTab === 'income' ? 'RMB' : '小时'}}</text>
            </view>
          </view>

          <view class="chart-card__rise">
            <image class="icon-xs" src="{{icons.trendingUp}}" mode="aspectFit" />
            <text class="chart-card__rise-text">{{vm.trend.riseText}}</text>
          </view>
        </view>
      </view>
    </view>



    <view class="report-section">
      <view class="report-section-head report-section-head--toolbar">
        <pp-section-header title="摸鱼占比统计" barTone="blue" trimBottom="{{true}}" />

        <view class="range-switch">
          <view class="range-switch__item {{timeRange === 'day' ? 'range-switch__item--active' : ''}} {{pressStates.rangeKey === 'day' ? 'range-switch__item--pressed' : ''}}" data-key="day" bind:tap="switchRange">
            <text class="range-switch__text">日</text>
          </view>
          <view class="range-switch__item {{timeRange === 'week' ? 'range-switch__item--active' : ''}} {{pressStates.rangeKey === 'week' ? 'range-switch__item--pressed' : ''}}" data-key="week" bind:tap="switchRange">
            <text class="range-switch__text">周</text>
          </view>
          <view class="range-switch__item {{timeRange === 'month' ? 'range-switch__item--active' : ''}} {{pressStates.rangeKey === 'month' ? 'range-switch__item--pressed' : ''}}" data-key="month" bind:tap="switchRange">
            <text class="range-switch__text">月</text>
          </view>
          <view class="range-switch__item {{timeRange === 'year' ? 'range-switch__item--active' : ''}} {{pressStates.rangeKey === 'year' ? 'range-switch__item--pressed' : ''}}" data-key="year" bind:tap="switchRange">
            <text class="range-switch__text">年</text>
          </view>
        </view>
      </view>

      <view class="ratio-card">
        <view class="ratio-card__ring-shell">
          <image class="ratio-card__ring-image" src="{{ratioRingSrc}}" mode="aspectFit" />
          <view class="ratio-card__ring-copy">
            <text class="ratio-card__ring-value">{{currentRatio.moyu}}%</text>
            <text class="ratio-card__ring-label">摸鱼占比</text>
          </view>
        </view>

        <view class="ratio-card__stats">
          <view class="ratio-stat">
            <view class="ratio-stat__head">
              <text class="ratio-stat__label">打工时长</text>
              <text class="ratio-stat__value">{{currentRatio.work}}%</text>
            </view>
            <view class="ratio-stat__track">
              <view class="ratio-stat__fill ratio-stat__fill--work" style="width: {{currentRatio.work}}%;"></view>
            </view>
          </view>

          <view class="ratio-stat">
            <view class="ratio-stat__head">
              <text class="ratio-stat__label ratio-stat__label--blue">摸鱼时长</text>
              <text class="ratio-stat__value ratio-stat__value--blue">{{currentRatio.moyu}}%</text>
            </view>
            <view class="ratio-stat__track ratio-stat__track--blue">
              <view class="ratio-stat__fill ratio-stat__fill--moyu" style="width: {{currentRatio.moyu}}%;"></view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="report-section report-section--last">
      <view class="report-section-head">
        <pp-section-header title="摸鱼记录" barTone="slate" trimBottom="{{true}}" />
      </view>

      <view wx:if="{{visibleHistoryItems.length}}">
        <view class="history-list">
          <block wx:for="{{visibleHistoryItems}}" wx:key="fullDate">
            <view class="history-row">
              <view class="history-row__date-col">
                <text class="history-row__date">{{item.displayDate}}</text>
              </view>

              <view class="history-row__metric">
                <view class="history-row__metric-head">
                  <image class="history-row__clock" src="{{icons.clock}}" mode="aspectFit" />
                  <text class="history-row__metric-label">摸鱼时长</text>
                </view>
                <text class="history-row__metric-value">{{item.duration}}</text>
              </view>

              <view class="history-row__income-col">
                <text class="history-row__income">+{{item.income}}</text>
                <text class="history-row__income-label">收益</text>
              </view>
            </view>
          </block>
        </view>

        <view class="history-pagination" wx:if="{{historyTotalPages > 1}}">
          <view class="history-pagination__btn {{historyPage <= 1 ? 'history-pagination__btn--disabled' : ''}} {{pressStates.historyPrev ? 'history-pagination__btn--pressed' : ''}}" bind:tap="goPrevHistoryPage">
            <text class="history-pagination__btn-text">上一页</text>
          </view>
          <text class="history-pagination__status">第 {{historyPage}} / {{historyTotalPages}} 页</text>
          <view class="history-pagination__btn {{historyPage >= historyTotalPages ? 'history-pagination__btn--disabled' : ''}} {{pressStates.historyNext ? 'history-pagination__btn--pressed' : ''}}" bind:tap="goNextHistoryPage">
            <text class="history-pagination__btn-text">下一页</text>
          </view>
        </view>
      </view>

      <view wx:else class="history-empty">
        <text class="history-empty__text">这个月还没有摸鱼记录，先去偷会儿闲吧。</text>
      </view>
    </view>
  </view>

  <view wx:if="{{showAnnualInfoModal}}" class="info-modal {{annualInfoModalVisible ? 'info-modal--visible' : ''}}" bind:tap="closeAnnualInfo">
    <view class="info-sheet {{annualInfoModalVisible ? 'info-sheet--visible' : ''}}" catch:tap="stopModalTap">
      <view class="info-sheet__header">
        <view class="info-sheet__titles">
          <text class="info-sheet__title">{{activeAnnualInfo.title}}</text>
          <text class="info-sheet__subtitle">查看这个指标的计算口径与工时明细</text>
        </view>
        <view class="info-sheet__close {{pressStates.annualInfoClose ? 'info-sheet__close--pressed' : ''}}" bind:tap="closeAnnualInfo">
          <image class="icon-lg" src="{{icons.x}}" mode="aspectFit" />
        </view>
      </view>

      <view class="info-sheet__body" wx:if="{{activeAnnualInfo}}">
        <view class="info-sheet__rule">
          <text class="info-sheet__rule-label">计算规则</text>
          <text class="info-sheet__rule-text">{{activeAnnualInfo.rule}}</text>
        </view>

        <view class="info-sheet__detail-block">
          <text class="info-sheet__detail-title">{{activeAnnualInfoKey === 'currentJobCompensation' ? '计算工龄' : '计算工时'}}</text>
          <block wx:for="{{activeAnnualInfo.details}}" wx:key="label">
            <view class="info-sheet__detail-row">
              <text class="info-sheet__detail-label">{{item.label}}</text>
              <text class="info-sheet__detail-value">{{item.value}}</text>
            </view>
          </block>
        </view>
      </view>
    </view>
  </view>
</view>
