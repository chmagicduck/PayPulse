<view class="page-view profile-page">
  <view class="profile-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="profile-nav__content">
      <view class="profile-nav__brand">
        <view class="profile-nav__logo" bind:tap="triggerHeaderAnimation">
          <image class="profile-nav__logo-icon" src="{{iconAnimations.header ? icons.headerPair.animatedSrc : icons.headerPair.staticSrc}}" mode="aspectFit" />
        </view>
        <text class="profile-nav__title">{{vm.header.title}}</text>
      </view>
    </view>
  </view>

  <view class="profile-main">
    <view class="profile-hero">
      <view class="profile-identity">
        <view class="avatar-shell {{pressStates.avatar ? 'avatar-shell--pressed' : ''}}" bind:tap="openAvatarModal">
          <view class="avatar-shell__frame avatar-shell__frame--{{currentRank.tone}}">
            <image class="avatar-shell__image" src="{{currentAvatar}}" mode="aspectFill" />
            <view class="avatar-shell__hint">
              <text class="avatar-shell__hint-text">{{vm.modal.avatarHint}}</text>
            </view>
          </view>
          <view class="avatar-shell__badge avatar-shell__badge--{{currentRank.tone}}">
            <image class="icon-sm" src="{{iconAnimations.avatarBadge ? currentRank.badgeIconPair.animatedSrc : currentRank.badgeIconPair.staticSrc}}" mode="aspectFit" />
          </view>
        </view>

        <view class="profile-identity__copy">
          <text class="profile-identity__name">{{vm.user.name}}</text>
          <view class="profile-identity__pill">
            <text class="profile-identity__pill-text">累计摸鱼打卡：{{vm.user.checkInDays}}天</text>
          </view>
        </view>
      </view>

      <view class="rank-card">
        <view class="rank-card__glow"></view>

        <view class="rank-card__head">
          <view class="rank-card__copy">
            <text class="rank-card__eyebrow">{{vm.rankPanel.eyebrow}}</text>
            <text class="rank-card__title rank-card__title--{{currentRank.tone}}">Lv.{{currentRank.level}} {{currentRank.name}}</text>
          </view>

          <view class="rank-card__today">
            <text class="rank-card__today-label">{{vm.rankPanel.todayLabel}}</text>
            <view class="rank-card__today-value-row">
              <text class="rank-card__today-value">{{todayHappiness}}</text>
              <text class="rank-card__today-unit">{{vm.rankPanel.todayUnit}}</text>
            </view>
          </view>
        </view>

        <view class="rank-card__progress">
          <view class="rank-card__progress-bar">
            <view class="rank-card__progress-fill rank-card__progress-fill--{{currentRank.tone}}" style="width: {{progressPercent}}%;"></view>
          </view>
          <view class="rank-card__progress-meta">
            <text class="rank-card__meta-text">{{vm.rankPanel.totalLabel}} {{totalHappiness}}</text>
            <text class="rank-card__meta-text" wx:if="{{nextRank}}">
              {{vm.rankPanel.nextLabel}}
              <text class="rank-card__meta-strong">{{pointsToNext}}</text>
            </text>
            <text class="rank-card__meta-text rank-card__meta-text--max" wx:else>{{vm.rankPanel.maxLabel}}</text>
          </view>
        </view>

        <view class="rank-axis">
          <view class="rank-axis__line"></view>
          <block wx:for="{{ranks}}" wx:key="level">
            <view
              class="rank-axis__item {{rankIndex === index ? 'rank-axis__item--active' : 'rank-axis__item--inactive'}} {{pressStates.rankIndex === index ? 'rank-axis__item--pressed' : ''}}"
              data-index="{{index}}"
              bind:tap="selectRank"
            >
              <view class="rank-axis__badge rank-axis__badge--{{item.tone}}">
                <image class="rank-axis__icon" src="{{iconAnimations.activeRankIndex === index ? item.axisIconPair.animatedSrc : item.axisIconPair.staticSrc}}" mode="aspectFit" />
              </view>
            </view>
          </block>
        </view>
      </view>
    </view>

    <view class="profile-section">
      <view class="section-head">
        <view class="section-head__bar section-head__bar--blue"></view>
        <text class="section-head__title">{{vm.sections.console.title}}</text>
      </view>

      <view class="menu-list">
        <block wx:for="{{consoleItems}}" wx:key="title">
          <view class="menu-card {{pressStates.consoleIndex === index ? 'menu-card--pressed' : ''}}" data-index="{{index}}" bind:tap="pressConsoleCard">
            <view class="menu-card__main">
              <view class="menu-card__icon menu-card__icon--{{item.tone}}">
                <image class="icon-md" src="{{iconAnimations.consoleIndex === index ? item.iconPair.animatedSrc : item.iconPair.staticSrc}}" mode="aspectFit" />
              </view>
              <view class="menu-card__copy">
                <view class="menu-card__title-row">
                  <text class="menu-card__title">{{item.title}}</text>
                  <view class="menu-card__badge" wx:if="{{item.badge}}">
                    <text class="menu-card__badge-text">{{item.badge}}</text>
                  </view>
                </view>
                <text class="menu-card__desc">{{item.desc}}</text>
              </view>
            </view>
            <image class="menu-card__arrow" src="{{icons.chevronRight}}" mode="aspectFit" />
          </view>
        </block>
      </view>
    </view>

    <view class="profile-section">
      <view class="section-head">
        <view class="section-head__bar section-head__bar--muted"></view>
        <text class="section-head__title">{{vm.sections.about.title}}</text>
      </view>

      <view class="support-list">
        <block wx:for="{{aboutItems}}" wx:key="title">
          <view class="support-row {{pressStates.aboutIndex === index ? 'support-row--pressed' : ''}}" data-index="{{index}}" bind:tap="pressAboutCard">
            <view class="support-row__main">
              <view class="support-row__icon">
                <image class="icon-md" src="{{iconAnimations.aboutIndex === index ? item.iconPair.animatedSrc : item.iconPair.staticSrc}}" mode="aspectFit" />
              </view>
              <view class="support-row__copy">
                <text class="support-row__title">{{item.title}}</text>
                <text class="support-row__desc">{{item.desc}}</text>
              </view>
            </view>
            <image class="support-row__arrow" src="{{icons.chevronRight}}" mode="aspectFit" />
          </view>
        </block>
      </view>
    </view>

    <view class="profile-section profile-section--last">
      <view class="section-head">
        <view class="section-head__bar section-head__bar--dark"></view>
        <text class="section-head__title">{{vm.sections.storage.sectionTitle}}</text>
      </view>

      <view class="storage-card {{pressStates.storage ? 'storage-card--pressed' : ''}}" bind:tap="pressStorageCard">
        <view class="storage-card__glow"></view>
        <view class="storage-card__content">
          <view class="storage-card__main">
            <view class="storage-card__icon">
              <image class="icon-lg" src="{{iconAnimations.storage ? storageCard.iconPair.animatedSrc : storageCard.iconPair.staticSrc}}" mode="aspectFit" />
            </view>
            <view class="storage-card__copy">
              <text class="storage-card__title">{{storageCard.title}}</text>
              <text class="storage-card__desc">{{storageCard.desc}}</text>
            </view>
          </view>
          <image class="storage-card__arrow" src="{{icons.chevronRight}}" mode="aspectFit" />
        </view>
      </view>
    </view>
  </view>

  <view class="avatar-modal {{avatarModalVisible ? 'avatar-modal--visible' : ''}}" wx:if="{{showAvatarModal}}" bind:tap="closeAvatarModal">
    <view class="avatar-sheet {{avatarModalVisible ? 'avatar-sheet--visible' : ''}}" catch:tap="">
      <view class="avatar-sheet__header">
        <view class="avatar-sheet__titles">
          <text class="avatar-sheet__title">{{vm.modal.title}}</text>
          <text class="avatar-sheet__subtitle">{{vm.modal.subtitle}}</text>
        </view>
        <view class="avatar-sheet__close {{pressStates.modalClose ? 'avatar-sheet__close--pressed' : ''}}" bind:tap="closeAvatarModal">
          <image class="icon-lg" src="{{icons.x}}" mode="aspectFit" />
        </view>
      </view>

      <view class="avatar-grid">
        <block wx:for="{{vm.avatarPresets}}" wx:key="id">
          <view class="avatar-grid__item {{draftAvatar === item.src ? 'avatar-grid__item--active' : ''}} {{pressStates.avatarOptionIndex === index ? 'avatar-grid__item--pressed' : ''}}" data-src="{{item.src}}" data-index="{{index}}" bind:tap="selectAvatar">
            <image class="avatar-grid__image" src="{{item.src}}" mode="aspectFill" />
            <view class="avatar-grid__selected" wx:if="{{draftAvatar === item.src}}">
              <image class="avatar-grid__check" src="{{icons.checkCircle2}}" mode="aspectFit" />
            </view>
          </view>
        </block>
      </view>

      <view class="avatar-sheet__confirm {{pressStates.modalConfirm ? 'avatar-sheet__confirm--pressed' : ''}}" bind:tap="confirmAvatar">
        <text class="avatar-sheet__confirm-text">{{vm.modal.confirmText}}</text>
      </view>
    </view>
  </view>
</view>
