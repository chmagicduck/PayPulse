<view class="page-view profile-page">
  <view class="profile-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="profile-nav__content">
      <view class="profile-nav__brand">
        <view class="profile-nav__logo" bind:tap="triggerHeaderAnimation">
          <image class="profile-nav__logo-icon" src="{{iconAnimations.header ? icons.headerPair.animatedSrc : icons.headerPair.staticSrc}}" mode="aspectFit" />
        </view>
        <text class="profile-nav__title">我的基地</text>
      </view>
    </view>
  </view>

  <view class="profile-main">
    <view class="profile-hero">
      <view class="profile-identity">
        <view class="avatar-shell {{pressStates.avatar ? 'avatar-shell--pressed' : ''}}" bind:tap="openAvatarModal">
          <view class="avatar-shell__frame avatar-shell__frame--{{currentRank.tone}}">
            <image class="avatar-shell__image" src="{{currentAvatar}}" mode="aspectFill" />
            <view class="avatar-shell__hint">
              <image class="avatar-shell__hint-icon" src="{{icons.camera}}" mode="aspectFit" />
            </view>
          </view>
          <view class="avatar-shell__badge avatar-shell__badge--{{currentRank.tone}}">
            <image class="icon-sm" src="{{iconAnimations.avatarBadge ? currentRank.iconPair.animatedSrc : currentRank.iconPair.staticSrc}}" mode="aspectFit" />
          </view>
        </view>

        <view class="profile-identity__copy">
          <view class="profile-identity__title-row">
            <text class="profile-identity__name">{{vm.user.name}}</text>
            <view class="profile-rank-pill profile-rank-pill--{{currentRank.tone}}">
              <text class="profile-rank-pill__text">Lv.{{currentRank.level}} {{currentRank.name}}</text>
            </view>
          </view>

          <view class="profile-identity__pill">
            <text class="profile-identity__pill-text">累计摸鱼天数：</text>
            <text class="profile-identity__pill-value">{{vm.user.checkInDays}}天</text>
          </view>
        </view>
      </view>
    </view>

    <view class="profile-section">
      <pp-section-header title="打工控制台" barTone="blue" />

      <view class="profile-card-list">
        <block wx:for="{{consoleItems}}" wx:key="cardKey">
          <pp-menu-card
            title="{{item.title}}"
            desc="{{item.desc}}"
            tone="{{item.tone}}"
            badge="{{item.badge}}"
            highlight="{{item.highlight}}"
            pressed="{{pressStates.cardKey === item.cardKey}}"
            iconSrc="{{iconAnimations.cardKey === item.cardKey ? item.iconPair.animatedSrc : item.iconPair.staticSrc}}"
            arrowSrc="{{icons.chevronRight}}"
            data-card-key="{{item.cardKey}}"
            data-url="{{item.url}}"
            data-nav-method="{{item.navMethod}}"
            bind:cardtap="pressMenuCard"
          />
        </block>
      </view>
    </view>

    <view class="profile-section">
      <pp-section-header title="摸鱼茶水间" barTone="indigo" />

      <view class="profile-card-list">
        <block wx:for="{{aboutItems}}" wx:key="cardKey">
          <pp-menu-card
            title="{{item.title}}"
            desc="{{item.desc}}"
            tone="{{item.tone}}"
            badge="{{item.badge}}"
            highlight="{{item.highlight}}"
            pressed="{{pressStates.cardKey === item.cardKey}}"
            iconSrc="{{iconAnimations.cardKey === item.cardKey ? item.iconPair.animatedSrc : item.iconPair.staticSrc}}"
            arrowSrc="{{icons.chevronRight}}"
            data-card-key="{{item.cardKey}}"
            data-url="{{item.url}}"
            data-nav-method="{{item.navMethod}}"
            bind:cardtap="pressMenuCard"
          />
        </block>
      </view>
    </view>

    <view class="profile-section profile-section--last">
      <pp-section-header title="数据与设置" barTone="dark" />

      <view class="profile-card-list">
        <block wx:for="{{storageItems}}" wx:key="cardKey">
          <pp-menu-card
            title="{{item.title}}"
            desc="{{item.desc}}"
            tone="{{item.tone}}"
            badge="{{item.badge}}"
            highlight="{{item.highlight}}"
            pressed="{{pressStates.cardKey === item.cardKey}}"
            iconSrc="{{iconAnimations.cardKey === item.cardKey ? item.iconPair.animatedSrc : item.iconPair.staticSrc}}"
            arrowSrc="{{icons.chevronRight}}"
            data-card-key="{{item.cardKey}}"
            data-url="{{item.url}}"
            data-nav-method="{{item.navMethod}}"
            bind:cardtap="pressMenuCard"
          />
        </block>
      </view>
    </view>
  </view>

  <view wx:if="{{showAvatarModal}}" class="avatar-modal {{avatarModalVisible ? 'avatar-modal--visible' : ''}}" bind:tap="closeAvatarModal">
    <view class="avatar-sheet {{avatarModalVisible ? 'avatar-sheet--visible' : ''}}" catch:tap="stopModalTap">
      <view class="avatar-sheet__header">
        <view class="avatar-sheet__titles">
          <text class="avatar-sheet__title">修改头像</text>
          <text class="avatar-sheet__subtitle">Change Identity</text>
        </view>
        <view class="avatar-sheet__close {{pressStates.modalClose ? 'avatar-sheet__close--pressed' : ''}}" bind:tap="closeAvatarModal">
          <image class="icon-lg" src="{{icons.x}}" mode="aspectFit" />
        </view>
      </view>

      <view class="avatar-sheet__action-row">
        <button
          class="avatar-sheet__action avatar-sheet__action-button avatar-sheet__action--emerald {{pressStates.wechatAvatar ? 'avatar-sheet__action--pressed' : ''}}"
          open-type="chooseAvatar"
          bind:tap="pressWechatAvatarAction"
          bind:chooseavatar="useWechatAvatar"
        >
          <image class="icon-md" src="{{icons.messageSquare}}" mode="aspectFit" />
          <text class="avatar-sheet__action-text">使用微信头像</text>
        </button>
        <button
          class="avatar-sheet__action avatar-sheet__action-button avatar-sheet__action--blue {{pressStates.uploadAvatar ? 'avatar-sheet__action--pressed' : ''}}"
          bind:tap="useUploadedAvatar"
        >
          <image class="icon-md" src="{{icons.cameraBlue}}" mode="aspectFit" />
          <text class="avatar-sheet__action-text">相册上传</text>
        </button>
      </view>

      <view class="avatar-sheet__tips">
        <text class="avatar-sheet__tips-text">相册上传头像需不超过 2MB</text>
      </view>

      <view class="avatar-sheet__preset-block">
        <text class="avatar-sheet__preset-title">默认头像</text>
      </view>

      <view class="avatar-grid">
        <block wx:for="{{vm.avatarPresets}}" wx:key="id">
          <view class="avatar-grid__item {{draftAvatar === item.src ? 'avatar-grid__item--active' : ''}} {{pressStates.avatarOptionIndex === index ? 'avatar-grid__item--pressed' : ''}}" data-src="{{item.src}}" data-index="{{index}}" bind:tap="selectAvatar">
            <image class="avatar-grid__image" src="{{item.src}}" mode="aspectFill" />
          </view>
        </block>
      </view>

      <view class="avatar-sheet__confirm {{pressStates.modalConfirm ? 'avatar-sheet__confirm--pressed' : ''}}" bind:tap="confirmAvatar">
        <text class="avatar-sheet__confirm-text">确定修改</text>
      </view>
    </view>
  </view>
</view>
