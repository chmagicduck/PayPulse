<template name="journey-value">
  <block wx:if="{{item.display.mode === 'days'}}">
    <text class="{{valueClass}}">{{item.display.major}}天</text>
  </block>
  <block wx:elif="{{item.display.mode === 'years'}}">
    <text class="{{valueClass}}">{{item.display.major}}年 {{item.display.middle}}个月 {{item.display.minor}}天</text>
  </block>
  <block wx:elif="{{item.display.mode === 'months'}}">
    <text class="{{valueClass}}">{{item.display.major}}个月 {{item.display.minor}}天</text>
  </block>
  <block wx:else>
    <text class="{{valueClass}}">{{item.display.major}}周 {{item.display.minor}}天</text>
  </block>
</template>

<view class="page-view home-page">
  <pp-brand-header
    paddingTop="{{statusBarHeight}}"
    title="薪潮涌动"
    logoSrc="{{iconAnimations.logo ? iconPairs.wavesWhite.animatedSrc : iconPairs.wavesWhite.staticSrc}}"
    logoBg="#2563eb"
    logoShadow="0 8rpx 24rpx rgba(37, 99, 235, 0.3)"
    bind:logotap="triggerLogoAnimation"
  />

  <view class="home-main">
    <view class="income-card">
      <view class="income-card__glow"></view>
      <view class="income-card__body">
        <view class="income-card__header">
          <view class="income-card__label-row">
            <text class="income-card__label">今日带薪摸鱼收益</text>
            <view class="income-card__eye" bind:tap="toggleAmount">
              <image class="icon-sm" src="{{showAmount ? iconEye : iconEyeOff}}" mode="aspectFit" />
            </view>
          </view>
        </view>

        <view class="income-card__hero">
          <view class="income-card__amount-wrap">
            <text class="income-card__value">{{showAmount ? vm.income.value : '***'}}</text>
            <view class="income-card__meta">
              <text class="income-card__badge-tag">当前搞钱速度 {{showAmount ? vm.income.rate : '***'}}/s</text>
            </view>
          </view>

          <view class="income-card__control">
            <view
              class="income-card__toggle {{isMoYu ? 'income-card__toggle--active' : ''}}"
              bind:tap="toggleMoYu"
              data-blocked-message="下班时间就别摸鱼了，好好生活"
            >
              <image class="income-card__toggle-icon" src="{{isMoYu ? (iconAnimations.moyu ? iconPairs.coffeeBlue.animatedSrc : iconPairs.coffeeBlue.staticSrc) : (iconAnimations.moyu ? iconPairs.coffeeWhite.animatedSrc : iconPairs.coffeeWhite.staticSrc)}}" mode="aspectFit" />
              <text class="income-card__toggle-text">{{isMoYu ? '摸鱼中' : '开始摸鱼'}}</text>
            </view>
            <view class="income-card__stay">
              <text class="income-card__stay-text">手动校准: {{vm.timer.rightValue}}</text>
              <view class="income-card__stay-action" catch:tap="openEditModal">
                <image class="income-card__stay-icon" src="{{iconSettingsSlate}}" mode="aspectFit" />
              </view>
            </view>
          </view>
        </view>

        <view class="income-card__progress-panel">
          <view class="income-card__progress-head">
            <view class="income-card__progress-copy">
              <text class="income-card__progress-title">摸鱼占比</text>
              <view class="income-card__progress-metrics">
                <text class="income-card__progress-value">{{vm.income.idlePercent}}%</text>
                <text class="income-card__progress-meta">/ 今日打工进度 {{vm.income.workPercent}}%</text>
              </view>
            </view>

            <view class="income-card__countdown">
              <view class="income-card__countdown-label">
                <image class="icon-xs" src="{{iconLogOut}}" mode="aspectFit" />
                <text>下班倒计时</text>
              </view>
              <block wx:if="{{vm.homeStatus.key === 'working'}}">
                <text class="income-card__countdown-value">{{vm.timer.leftValue}}</text>
              </block>
              <block wx:elif="{{vm.homeStatus.key === 'pre-work'}}">
                <text class="income-card__countdown-value">还没上班</text>
              </block>
              <block wx:elif="{{vm.homeStatus.key === 'lunch-break'}}">
                <text class="income-card__countdown-value">干饭中</text>
              </block>
              <block wx:elif="{{vm.homeStatus.key === 'off-duty'}}">
                <text class="income-card__countdown-value">已下班</text>
              </block>
              <block wx:else>
                <text class="income-card__countdown-value">休息中</text>
              </block>
            </view>
          </view>

          <view class="income-card__bar">
            <view class="income-card__bar-idle" style="width: {{vm.income.idlePercent}}%"></view>
            <view class="income-card__bar-work" style="width: {{vm.income.workPercent}}%"></view>
          </view>

          <view class="income-card__footer">
            <view class="income-card__stat income-card__stat--left">
              <text class="income-card__footer-label">今日工资</text>
              <text class="income-card__stat-value">{{showAmount ? vm.income.moyuIncome : '***'}}</text>
            </view>
            <view class="income-card__stat">
              <text class="income-card__footer-label">本月工资</text>
              <text class="income-card__stat-value">{{showAmount ? vm.income.monthlyIncome : '***'}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <pp-section-header
        title="日常摸鱼任务"
        barTone="blue"
        manageText="待领取 {{vm.taskPreview.rewardValue}} 摸鱼值"
        manageTone="blue"
        chevronSrc="{{iconChevronRightBlue}}"
        bind:manage="openLabPage"
      />
      <swiper
        class="task-swiper"
        circular="{{vm.dailyTasks.length > 1}}"
        interval="3200"
        duration="420"
        indicator-dots="{{false}}"
      >
        <block wx:for="{{vm.dailyTasks}}" wx:key="id">
          <swiper-item class="task-swiper__item">
            <pp-task-card
              variant="full"
              taskId="{{item.id}}"
              title="{{item.title}}"
              desc="{{item.desc}}"
              tone="{{item.tone}}"
            badgeText="{{item.badgeText}}"
            iconSrc="{{item.iconSrc}}"
            countText="{{item.countText}}"
            progressLabel="完成进度"
            progressPercent="{{item.progressPercent}}"
            done="{{item.done}}"
            rotate="{{item.rotate}}"
            showControls="{{true}}"
            minusDisabled="{{item.count <= 0}}"
            plusDisabled="{{item.count >= item.limit}}"
            minusPressed="{{taskActionKey === item.minusActionKey}}"
            plusPressed="{{taskActionKey === item.plusActionKey}}"
            bind:adjust="adjustHomeTask"
          />
        </swiper-item>
      </block>
      </swiper>
    </view>

    <view class="section">
      <pp-section-header
        title="日常盼头"
        barTone="indigo"
        manageText="查看日历"
        manageTone="blue"
        chevronSrc="{{iconChevronRightBlue}}"
        bind:manage="openCalendarPage"
      />
      <view class="tide-grid">
        <block wx:for="{{tideCards}}" wx:key="key">
          <view class="tide-grid__item">
            <pp-metric-card
              class="tide-grid__card"
              cardKey="{{item.key}}"
              variant="{{item.variant}}"
              tone="{{item.tone}}"
              iconSrc="{{item.key === 'salary' ? (iconAnimations.tideWallet ? item.animatedIconSrc : item.iconSrc) : (iconAnimations.tideWeekend ? item.animatedIconSrc : item.iconSrc)}}"
              ghostSrc="{{item.key === 'salary' ? (iconAnimations.tideWallet ? item.animatedGhostSrc : item.ghostSrc) : (iconAnimations.tideWeekend ? item.animatedGhostSrc : item.ghostSrc)}}"
              badgeText="{{item.badgeText}}"
              valuePrefix="{{item.valuePrefix}}"
              valueText="{{item.valueText}}"
              descPrefix="{{item.descPrefix}}"
              descStrong="{{item.descStrong}}"
              descSuffix="{{item.descSuffix}}"
              descStrongTone="{{item.descStrongTone}}"
              pressed="{{item.key === 'salary' ? pressStates.tideWallet : pressStates.tideWeekend}}"
              bind:cardtap="handleTideCardTap"
            />
          </view>
        </block>
      </view>
    </view>

    <view class="section">
      <pp-section-header
        title="纪念日"
        barTone="blue"
        manageText="新增纪念日"
        manageTone="blue"
        chevronSrc="{{iconChevronRightBlue}}"
        bind:manage="openTimeAxisPage"
      />

      <view class="dates-list" wx:if="{{vm.importantDates.length}}">
        <view wx:if="{{vm.importantDates[0]}}" class="date-item {{pressStates.dateHeart ? 'date-item--pressed' : ''}}" bind:tap="triggerDateHeartAnimation">
          <view class="date-item__main">
            <view class="date-item__icon date-item__icon--{{vm.importantDates[0].tone}}">
              <image class="date-item__icon-image" src="{{iconAnimations.dateHeart ? iconPairs.heartRose.animatedSrc : iconPairs.heartRose.staticSrc}}" mode="aspectFit" />
            </view>
            <view class="date-item__copy">
              <text class="date-item__title">{{vm.importantDates[0].title}}</text>
              <view class="date-item__meta">
                <text class="date-item__date">{{vm.importantDates[0].date}}</text>
                <view class="date-item__badge date-item__badge--{{vm.importantDates[0].tone}}">
                  <text class="date-item__badge-text">
                    <block wx:if="{{vm.importantDates[0].notebookId === 'commemorative'}}">纪念本</block>
                    <block wx:elif="{{vm.importantDates[0].notebookId === 'travel'}}">旅行本</block>
                    <block wx:elif="{{vm.importantDates[0].notebookId === 'career'}}">打工本</block>
                    <block wx:else>人生本</block>
                  </text>
                </view>
              </view>
            </view>
          </view>
          <view class="date-item__countdown">
            <text class="date-item__days date-item__days--{{vm.importantDates[0].tone}}">{{vm.importantDates[0].remaining}}</text>
            <text class="date-item__suffix">{{vm.importantDates[0].isPast ? '天前' : '天后'}}</text>
          </view>
        </view>

        <view wx:if="{{vm.importantDates[1]}}" class="date-item {{pressStates.dateGift ? 'date-item--pressed' : ''}}" bind:tap="triggerDateGiftAnimation">
          <view class="date-item__main">
            <view class="date-item__icon date-item__icon--{{vm.importantDates[1].tone}}">
              <image class="date-item__icon-image" src="{{iconAnimations.dateGift ? iconPairs.giftAmber.animatedSrc : iconPairs.giftAmber.staticSrc}}" mode="aspectFit" />
            </view>
            <view class="date-item__copy">
              <text class="date-item__title">{{vm.importantDates[1].title}}</text>
              <view class="date-item__meta">
                <text class="date-item__date">{{vm.importantDates[1].date}}</text>
                <view class="date-item__badge date-item__badge--{{vm.importantDates[1].tone}}">
                  <text class="date-item__badge-text">
                    <block wx:if="{{vm.importantDates[1].notebookId === 'commemorative'}}">纪念本</block>
                    <block wx:elif="{{vm.importantDates[1].notebookId === 'travel'}}">旅行本</block>
                    <block wx:elif="{{vm.importantDates[1].notebookId === 'career'}}">打工本</block>
                    <block wx:else>人生本</block>
                  </text>
                </view>
              </view>
            </view>
          </view>
          <view class="date-item__countdown">
            <text class="date-item__days date-item__days--{{vm.importantDates[1].tone}}">{{vm.importantDates[1].remaining}}</text>
            <text class="date-item__suffix">{{vm.importantDates[1].isPast ? '天前' : '天后'}}</text>
          </view>
        </view>

        <view wx:if="{{vm.importantDates[2]}}" class="date-item {{pressStates.dateStar ? 'date-item--pressed' : ''}}" bind:tap="triggerDateStarAnimation">
          <view class="date-item__main">
            <view class="date-item__icon date-item__icon--{{vm.importantDates[2].tone}}">
              <image class="date-item__icon-image" src="{{iconAnimations.dateStar ? iconPairs.starBlue.animatedSrc : iconPairs.starBlue.staticSrc}}" mode="aspectFit" />
            </view>
            <view class="date-item__copy">
              <text class="date-item__title">{{vm.importantDates[2].title}}</text>
              <view class="date-item__meta">
                <text class="date-item__date">{{vm.importantDates[2].date}}</text>
                <view class="date-item__badge date-item__badge--{{vm.importantDates[2].tone}}">
                  <text class="date-item__badge-text">
                    <block wx:if="{{vm.importantDates[2].notebookId === 'commemorative'}}">纪念本</block>
                    <block wx:elif="{{vm.importantDates[2].notebookId === 'travel'}}">旅行本</block>
                    <block wx:elif="{{vm.importantDates[2].notebookId === 'career'}}">打工本</block>
                    <block wx:else>人生本</block>
                  </text>
                </view>
              </view>
            </view>
          </view>
          <view class="date-item__countdown">
            <text class="date-item__days date-item__days--{{vm.importantDates[2].tone}}">{{vm.importantDates[2].remaining}}</text>
            <text class="date-item__suffix">{{vm.importantDates[2].isPast ? '天前' : '天后'}}</text>
          </view>
        </view>
      </view>
      <view wx:else class="date-empty" bind:tap="openTimeAxisPage">
        <text class="date-empty__text">这里空空如也，点击加个纪念日吧。</text>
      </view>
    </view>

    <view class="section section--last">
      <pp-section-header
        title="人生进度条"
        barTone="dark"
        tagText="Voyage Ledger"
      />

      <view class="journey-list">
        <block wx:for="{{journeySummaryCards}}" wx:key="key">
          <pp-metric-card
            class="journey-list__card"
            cardKey="{{item.key}}"
            variant="{{item.variant}}"
            tone="{{item.tone}}"
            iconSrc="{{item.key === 'life' ? (iconAnimations.journeyLife ? item.animatedIconSrc : item.iconSrc) : (iconAnimations.journeyCareer ? item.animatedIconSrc : item.iconSrc)}}"
            ghostSrc="{{item.key === 'life' ? (iconAnimations.journeyLife ? item.animatedGhostSrc : item.ghostSrc) : (iconAnimations.journeyCareer ? item.animatedGhostSrc : item.ghostSrc)}}"
            badgeText="{{item.badgeText}}"
            valuePrefix="{{item.valuePrefix}}"
            valueText="{{item.valueText}}"
            descPrefix="{{item.descPrefix}}"
            descStrong="{{item.descStrong}}"
            descSuffix="{{item.descSuffix}}"
            descStrongTone="{{item.descStrongTone}}"
            pressed="{{item.key === 'life' ? pressStates.journeyLife : pressStates.journeyCareer}}"
            bind:cardtap="handleJourneySummaryCardTap"
          />
        </block>

        <view class="journey-card journey-card--emerald {{pressStates.journeyRetire ? 'journey-card--pressed' : ''}}" bind:tap="triggerJourneyRetireAnimation">
          <image class="journey-card__ghost journey-card__ghost--emerald" src="{{iconAnimations.journeyRetire ? iconPairs.flagEmerald.animatedSrc : iconPairs.flagEmerald.staticSrc}}" mode="aspectFit" />
          <view class="journey-card__head">
            <view class="journey-card__icon journey-card__icon--emerald">
              <image class="icon-md" src="{{iconAnimations.journeyRetire ? iconPairs.flagWhite.animatedSrc : iconPairs.flagWhite.staticSrc}}" mode="aspectFit" />
            </view>
            <text class="journey-card__eyebrow journey-card__eyebrow--emerald">退休倒计时</text>
          </view>
          <view class="journey-card__number">
            <text class="journey-card__status journey-card__status--emerald">还要熬</text>
            <template is="journey-value" data="{{ item: journeyDisplayItems[2], valueClass: 'journey-card__value journey-card__value--emerald' }}" />
          </view>
          <text class="journey-card__desc journey-card__desc--emerald">距离你可以<text class="journey-card__desc-strong journey-card__desc-strong--emerald">光荣退休</text>，还有这么久的班要上。</text>
          <view class="journey-card__progress">
            <view class="journey-card__progress-fill" style="width: {{journeyDisplayItems[2].progress ? journeyDisplayItems[2].progress : 0}}%"></view>
          </view>
        </view>

        <view class="journey-card journey-card--rose {{pressStates.journeyFinal ? 'journey-card--pressed' : ''}}" bind:tap="triggerJourneyFinalAnimation">
          <image class="journey-card__ghost journey-card__ghost--rose" src="{{iconAnimations.journeyFinal ? iconPairs.skullRose.animatedSrc : iconPairs.skullRose.staticSrc}}" mode="aspectFit" />
          <view class="journey-card__head">
            <view class="journey-card__icon journey-card__icon--rose">
              <image class="icon-md" src="{{iconAnimations.journeyFinal ? iconPairs.skullWhite.animatedSrc : iconPairs.skullWhite.staticSrc}}" mode="aspectFit" />
            </view>
            <text class="journey-card__eyebrow journey-card__eyebrow--rose">人终有一老</text>
          </view>
          <view class="journey-card__number">
            <text class="journey-card__status journey-card__status--rose">还剩</text>
            <template is="journey-value" data="{{ item: journeyDisplayItems[3], valueClass: 'journey-card__value journey-card__value--rose' }}" />
          </view>
          <text class="journey-card__quote">"生命宝贵，不要全浪费在给别人打工上。"</text>
          <view class="journey-card__note">
            <text class="journey-card__note-text">* 假设你能活到 85 岁。每一秒都很宝贵，多摸会儿鱼吧。</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view
    wx:if="{{taskNotice.text}}"
    class="task-notice task-notice--tone-{{taskNotice.tone}} {{taskNotice.active ? 'task-notice--active' : ''}}"
  >
    <text class="task-notice__text">{{taskNotice.text}}</text>
  </view>

  <view wx:if="{{showEditModal}}" class="modal-overlay {{editModalVisible ? 'modal-overlay--visible' : ''}}" bind:tap="closeEditModal">
    <view class="modal-sheet {{editModalVisible ? 'modal-sheet--visible' : ''}}" catch:tap="stopModalTap">
      <view class="modal-sheet__header">
        <view class="modal-sheet__titles">
          <text class="modal-sheet__title">修正摸鱼时长</text>
          <text class="modal-sheet__subtitle">手动调整今天的摸鱼时间</text>
        </view>
        <view class="modal-sheet__close {{pressStates.modalClose ? 'modal-sheet__close--pressed' : ''}}" bind:tap="closeEditModal">
          <image class="icon-lg" src="{{iconX}}" mode="aspectFit" />
        </view>
      </view>
      <view class="modal-sheet__inputs">
        <view class="time-input">
          <input class="time-input__field" type="number" value="{{editH}}" data-field="editH" data-max="23" bindinput="updateTimeField" bindblur="normalizeTimeField" maxlength="2" />
          <text class="time-input__label">时</text>
        </view>
        <text class="time-input__sep">:</text>
        <view class="time-input">
          <input class="time-input__field" type="number" value="{{editM}}" data-field="editM" data-max="59" bindinput="updateTimeField" bindblur="normalizeTimeField" maxlength="2" />
          <text class="time-input__label">分</text>
        </view>
        <text class="time-input__sep">:</text>
        <view class="time-input">
          <input class="time-input__field" type="number" value="{{editS}}" data-field="editS" data-max="59" bindinput="updateTimeField" bindblur="normalizeTimeField" maxlength="2" />
          <text class="time-input__label">秒</text>
        </view>
      </view>
      <view class="modal-sheet__actions">
        <view class="modal-sheet__btn modal-sheet__btn--cancel" bind:tap="closeEditModal">
          <text>取消</text>
        </view>
        <view class="modal-sheet__btn modal-sheet__btn--confirm {{pressStates.modalConfirm ? 'modal-sheet__btn--confirm-pressed' : ''}}" bind:tap="saveEditTime">
          <text>确认保存</text>
        </view>
      </view>
    </view>
  </view>
</view>
