<view class="page-view lab-page">
  <view class="lab-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="lab-nav__content">
      <view class="lab-nav__brand">
        <view class="lab-nav__logo" bind:tap="triggerHeaderAnimation">
          <image class="lab-nav__logo-icon" src="{{iconAnimations.header ? icons.labPair.animatedSrc : icons.labPair.staticSrc}}" mode="aspectFit" />
        </view>
        <text class="lab-nav__title">{{vm.header.title}}</text>
      </view>
    </view>
  </view>

  <view class="lab-main">
    <view class="rank-card">
      <view class="rank-card__glow"></view>

      <view class="rank-card__head">
        <view class="rank-card__copy">
          <text class="rank-card__eyebrow">{{vm.rankPanel.eyebrow}}</text>
          <text class="rank-card__title rank-card__title--{{currentRank.tone}}">Lv.{{currentRank.level}} {{currentRank.name}}</text>
        </view>

        <view class="rank-card__today">
          <text class="rank-card__today-label">{{vm.rankPanel.todayLabel}}</text>
          <view class="rank-card__today-value-row">
            <text class="rank-card__today-value">{{todayHappiness}}</text>
            <text class="rank-card__today-unit">{{vm.rankPanel.todayUnit}}</text>
          </view>
        </view>
      </view>

      <view class="rank-card__progress">
        <view class="rank-card__progress-bar">
          <view class="rank-card__progress-fill rank-card__progress-fill--{{currentRank.tone}}" style="width: {{progressPercent}}%;"></view>
        </view>
        <view class="rank-card__progress-meta">
          <text class="rank-card__meta-text">{{vm.rankPanel.totalLabel}} {{totalHappiness}}</text>
          <text class="rank-card__meta-text" wx:if="{{nextRank}}">{{vm.rankPanel.nextLabel}} <text class="rank-card__meta-strong">{{pointsToNext}}</text></text>
          <text class="rank-card__meta-text rank-card__meta-text--max" wx:else>{{vm.rankPanel.maxLabel}}</text>
        </view>
      </view>

      <view class="rank-axis">
        <view class="rank-axis__line"></view>
        <block wx:for="{{ranks}}" wx:key="level">
          <view
            class="rank-axis__item {{rankIndex === index ? 'rank-axis__item--active' : 'rank-axis__item--inactive'}} {{pressStates.rankIndex === index ? 'rank-axis__item--pressed' : ''}}"
            data-index="{{index}}"
            bind:tap="selectRank"
          >
            <view class="rank-axis__badge rank-axis__badge--{{item.tone}}">
              <image class="rank-axis__icon" src="{{iconAnimations.activeRankIndex === index ? item.axisIconPair.animatedSrc : item.axisIconPair.staticSrc}}" mode="aspectFit" />
            </view>
          </view>
        </block>
      </view>
    </view>

    <view class="lab-section">
      <view class="section-head">
        <text class="section-head__title">{{vm.sections.tasks.title}}</text>
        <text class="section-head__subtitle">{{vm.sections.tasks.subtitle}}</text>
      </view>

      <view class="task-list">
        <block wx:for="{{tasks}}" wx:key="id">
          <view class="task-card">
            <view class="task-card__top">
              <view class="task-card__main">
                <view class="task-card__icon-shell">
                  <view class="task-card__icon task-card__icon--{{item.tone}}">
                    <image class="task-card__icon-image {{item.rotate ? 'task-card__icon-image--rotate' : ''}}" src="{{iconAnimations.activeTaskId === item.id ? item.iconPair.animatedSrc : item.iconPair.staticSrc}}" mode="aspectFit" />
                  </view>
                  <view class="task-card__copy">
                    <text class="task-card__title">{{item.title}}</text>
                    <text class="task-card__desc">{{item.desc}}</text>
                  </view>
                </view>

                <view class="task-card__badge {{item.done ? 'task-card__badge--done' : 'task-card__badge--active'}}">
                  <text class="task-card__badge-text">{{item.badgeText}}</text>
                </view>
              </view>
            </view>

            <view class="task-card__bottom">
              <view class="task-card__progress">
                <view class="task-card__progress-head">
                  <text class="task-card__progress-label">{{vm.sections.tasks.progressLabel}}</text>
                  <text class="task-card__count">{{item.countText}}</text>
                </view>
                <view class="task-card__progress-track">
                  <view class="task-card__progress-fill task-card__progress-fill--{{item.done ? 'done' : item.tone}}" style="width: {{item.progressPercent}}%;"></view>
                </view>
              </view>

              <view class="task-card__controls">
                <view
                  class="task-card__control-btn {{pressStates.taskActionKey === item.minusActionKey ? 'task-card__control-btn--pressed' : ''}} {{item.count <= 0 ? 'task-card__control-btn--disabled' : ''}}"
                  data-id="{{item.id}}"
                  data-delta="-1"
                  catch:tap="adjustTask"
                >
                  <image class="task-card__control-icon" src="{{icons.minusSlate}}" mode="aspectFit" />
                </view>
                <view
                  class="task-card__control-btn {{pressStates.taskActionKey === item.plusActionKey ? 'task-card__control-btn--pressed' : ''}} {{item.count >= item.limit ? 'task-card__control-btn--disabled' : ''}}"
                  data-id="{{item.id}}"
                  data-delta="1"
                  catch:tap="adjustTask"
                >
                  <image class="task-card__control-icon" src="{{icons.plusSlate}}" mode="aspectFit" />
                </view>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <view class="lab-section lab-section--last">
      <view class="section-head">
        <text class="section-head__title">{{vm.sections.achievements.title}}</text>
      </view>

      <view class="achievement-list">
        <block wx:for="{{achievements}}" wx:key="id">
          <view class="achievement-card">
            <image class="achievement-card__ghost" src="{{icons.medalGhost}}" mode="aspectFit" />

            <view class="achievement-card__content">
              <view class="achievement-card__head">
                <view class="achievement-card__icon">
                  <image class="icon-md" src="{{icons.trophyAmber}}" mode="aspectFit" />
                </view>

                <view class="achievement-card__copy">
                  <view class="achievement-card__title-row">
                    <view class="achievement-card__titles">
                      <text class="achievement-card__title">{{item.title}}</text>
                      <text class="achievement-card__desc">{{item.desc}}</text>
                    </view>
                    <text class="achievement-card__reward">{{vm.sections.achievements.rewardPrefix}}{{item.reward}}</text>
                  </view>
                </view>
              </view>

              <view class="achievement-card__progress">
                <view class="achievement-card__track">
                  <view class="achievement-card__fill" style="width: {{item.progressPercent}}%;"></view>
                </view>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>
</view>
