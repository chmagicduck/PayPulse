<view class="page-view time-axis-page">
  <view class="time-axis-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="time-axis-nav__content">
      <view class="time-axis-nav__back" bind:tap="handleBack">
        <image class="time-axis-nav__back-icon" src="{{icons.chevronLeft}}" mode="aspectFit" />
      </view>
      <text class="time-axis-nav__title">{{vm.title}}</text>
      <view class="time-axis-nav__spacer"></view>
    </view>
  </view>

  <view class="notebook-strip">
    <block wx:for="{{notebooks}}" wx:key="id">
      <view
        class="notebook-card {{selectedNotebookId === item.id ? 'notebook-card--active' : ''}} {{pressStates.notebookId === item.id ? 'notebook-card--pressed' : ''}}"
        data-id="{{item.id}}"
        bind:tap="selectNotebook"
      >
        <view class="notebook-card__stack"></view>
        <view class="notebook-card__body notebook-card__body--{{item.tone}}">
          <view class="notebook-card__bookmark notebook-card__bookmark--{{item.tone}}"></view>
          <view class="notebook-card__stitch"></view>
          <view class="notebook-card__icon-shell">
            <image
              class="notebook-card__icon"
              src="{{selectedNotebookId === item.id ? item.iconPair.animatedSrc : item.iconPair.staticSrc}}"
              mode="aspectFit"
            />
          </view>
          <text class="notebook-card__name">{{item.name}}</text>
        </view>
      </view>
    </block>
  </view>

  <view class="time-axis-main">
    <view class="entry-list" wx:if="{{visibleEntries.length}}">
      <block wx:for="{{visibleEntries}}" wx:key="id">
        <view
          class="entry-card {{pressStates.entryId === item.id ? 'entry-card--pressed' : ''}}"
          data-id="{{item.id}}"
          bind:tap="openEditDrawer"
        >
          <view class="entry-card__main">
            <view class="entry-card__icon entry-card__icon--{{item.tone}}">
              <image class="entry-card__icon-image" src="{{item.iconSrc}}" mode="aspectFit" />
            </view>

            <view class="entry-card__copy">
              <text class="entry-card__title">{{item.title}}</text>
              <view class="entry-card__meta">
                <text class="entry-card__date">{{item.dateText}}</text>
                <view class="entry-card__badge entry-card__badge--{{item.notebookTone}}">
                  <text class="entry-card__badge-text">{{item.notebookName}}</text>
                </view>
              </view>
            </view>
          </view>

          <view class="entry-card__countdown">
            <text class="entry-card__value entry-card__value--{{item.tone}} {{item.isPast ? 'entry-card__value--past' : ''}}">{{item.valueText}}</text>
            <text class="entry-card__unit">{{item.unitText}}</text>
          </view>
        </view>
      </block>
    </view>

    <view class="entry-empty" wx:else>
      <image class="entry-empty__icon" src="{{icons.emptyPair.staticSrc}}" mode="aspectFit" />
      <text class="entry-empty__title">{{vm.texts.emptyTitle}}</text>
    </view>

    <view class="archive-cta {{pressStates.addCard ? 'archive-cta--pressed' : ''}}" bind:tap="openCreateDrawer">
      <view class="archive-cta__icon">
        <image
          class="archive-cta__icon-image"
          src="{{pressStates.addCard ? icons.addPair.animatedSrc : icons.addPair.staticSrc}}"
          mode="aspectFit"
        />
      </view>
      <text class="archive-cta__text">{{vm.texts.addCta}}</text>
    </view>
  </view>

    <view wx:if="{{showDrawer}}" class="drawer-overlay {{drawerVisible ? 'drawer-overlay--visible' : ''}}" bind:tap="closeDrawer">
    <view class="drawer-sheet {{drawerVisible ? 'drawer-sheet--visible' : ''}}" catch:tap="noop">
      <view class="drawer-sheet__header">
        <text class="drawer-sheet__title">{{editingId ? vm.texts.editTitle : vm.texts.createTitle}}</text>
        <view class="drawer-sheet__close {{pressStates.closeButton ? 'drawer-sheet__close--pressed' : ''}}" bind:tap="pressCloseDrawer">
          <image class="drawer-sheet__close-icon" src="{{icons.close}}" mode="aspectFit" />
        </view>
      </view>

      <view class="drawer-field">
        <text class="drawer-field__label">{{vm.texts.titleField}}</text>
        <input
          class="drawer-field__input"
          value="{{form.title}}"
          maxlength="20"
          placeholder="{{vm.texts.titlePlaceholder}}"
          bindinput="updateTitle"
        />
      </view>

      <view class="drawer-field">
        <text class="drawer-field__label">{{vm.texts.dateField}}</text>
        <picker mode="date" value="{{form.date}}" bindchange="updateDate">
          <view class="drawer-field__picker {{form.date ? '' : 'drawer-field__picker--placeholder'}}">
            <view class="drawer-field__picker-main">
              <image class="drawer-field__picker-icon" src="{{icons.calendar}}" mode="aspectFit" />
              <text class="drawer-field__picker-text">{{form.date || '请选择日期'}}</text>
            </view>
          </view>
        </picker>
      </view>

      <view class="drawer-switch {{pressStates.anniversary ? 'drawer-switch--pressed' : ''}}" bind:tap="toggleAnniversary">
        <view class="drawer-switch__copy">
          <text class="drawer-switch__title">{{vm.texts.anniversaryTitle}}</text>
          <text class="drawer-switch__subtitle">{{vm.texts.anniversarySubtitle}}</text>
        </view>
        <view class="drawer-switch__track {{form.isAnniversary ? 'drawer-switch__track--active' : ''}}">
          <view class="drawer-switch__thumb"></view>
        </view>
      </view>

      <view class="drawer-field drawer-field--last">
        <text class="drawer-field__label">{{vm.texts.notebookField}}</text>
        <view class="drawer-notebooks">
          <block wx:for="{{drawerNotebooks}}" wx:key="id">
            <view
              class="drawer-notebook drawer-notebook--{{item.tone}} {{form.notebookId === item.id ? 'drawer-notebook--active' : ''}} {{pressStates.drawerNotebookId === item.id ? 'drawer-notebook--pressed' : ''}}"
              data-id="{{item.id}}"
              bind:tap="selectDrawerNotebook"
            >
              <view class="drawer-notebook__bookmark drawer-notebook__bookmark--{{item.tone}}"></view>
              <image
                class="drawer-notebook__icon"
                src="{{form.notebookId === item.id ? item.iconPair.animatedSrc : item.iconPair.staticSrc}}"
                mode="aspectFit"
              />
              <text class="drawer-notebook__name">{{item.name}}</text>
            </view>
          </block>
        </view>
      </view>

      <view class="drawer-actions">
        <view
          wx:if="{{editingId}}"
          class="drawer-actions__delete {{pressStates.deleteButton ? 'drawer-actions__delete--pressed' : ''}}"
          bind:tap="deleteEntry"
        >
          <image class="drawer-actions__delete-icon" src="{{icons.trash2}}" mode="aspectFit" />
        </view>

        <view class="drawer-actions__primary {{pressStates.saveButton ? 'drawer-actions__primary--pressed' : ''}}" bind:tap="saveEntry">
          <text class="drawer-actions__primary-text">{{editingId ? vm.texts.confirmSave : vm.texts.confirmCreate}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
