<view class="page-view settings-page">
  <view class="settings-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="settings-nav__content">
      <view class="settings-nav__back" bind:tap="handleBack">
        <image class="icon-lg" src="{{icons.chevronLeft}}" mode="aspectFit" />
      </view>
      <text class="settings-nav__title">航行档案设置</text>
      <view class="settings-nav__placeholder"></view>
    </view>
  </view>

  <view class="settings-main">
    <view class="settings-banner" bind:tap="triggerBannerAnimation">
      <view class="settings-banner__icon">
        <image class="icon-lg" src="{{iconAnimations.banner ? icons.compassPair.animatedSrc : icons.compassPair.staticSrc}}" mode="aspectFit" />
      </view>
      <view class="settings-banner__copy">
        <text class="settings-banner__title">校准你的航向（完善基础参数）</text>
        <text class="settings-banner__desc">输入航行坐标参数，用于推演你的时间分布、航程节奏与长期轨迹。</text>
      </view>
      <image class="settings-banner__anchor" src="{{icons.anchor}}" mode="aspectFit" />
    </view>

    <view class="settings-section">
      <pp-section-header title="船员身份识别（用户基础资料）" barTone="blue" />

      <view class="field">
        <view class="field__label">
          <image class="icon-xs" src="{{icons.user}}" mode="aspectFit" />
          <text>专属代号（用户昵称）</text>
        </view>
        <input class="field__input" value="{{form.nickname}}" data-field="nickname" bindinput="updateField" />
      </view>

      <view class="field-grid">
        <view class="field">
          <view class="field__label">
            <image class="icon-xs" src="{{icons.calendar}}" mode="aspectFit" />
            <text>出厂日期（出生日期）</text>
          </view>
          <picker mode="date" value="{{form.birthday}}" data-field="birthday" bindchange="updateField">
            <view class="field__picker">{{form.birthday}}</view>
          </picker>
        </view>

        <view class="field">
          <view class="field__label">
            <image class="icon-xs" src="{{icons.user}}" mode="aspectFit" />
            <text>生命取向（性别）</text>
          </view>
          <view class="segmented">
            <view class="segmented__item {{form.gender === 'male' ? 'segmented__item--active' : ''}}" data-value="male" bind:tap="chooseGender">
              <text class="segmented__text">男性</text>
            </view>
            <view class="segmented__item {{form.gender === 'female' ? 'segmented__item--active' : ''}}" data-value="female" bind:tap="chooseGender">
              <text class="segmented__text">女性</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="settings-section">
      <pp-section-header title="航程工龄坐标（职业与收入参数）" barTone="blue" />

      <view class="field">
        <view class="field__label">
          <image class="icon-xs" src="{{icons.briefcase}}" mode="aspectFit" />
          <text>首次入港日期（参加工作日期）</text>
        </view>
        <picker mode="date" value="{{form.careerStartDate}}" data-field="careerStartDate" bindchange="updateField">
          <view class="field__picker">{{form.careerStartDate}}</view>
        </picker>
      </view>

      <view class="field-grid">
        <view class="field">
          <view class="field__label">
            <image class="icon-xs" src="{{icons.moon}}" mode="aspectFit" />
            <text>预计退休（退休年龄）</text>
          </view>
          <input class="field__input" type="number" value="{{form.retirementAge}}" data-field="retirementAge" bindinput="updateField" />
        </view>

        <view class="field">
          <view class="field__label">
            <image class="icon-xs" src="{{icons.sun}}" mode="aspectFit" />
            <text>预期寿命（生命周期估算）</text>
          </view>
          <input class="field__input" type="number" value="{{form.expectedLifespan}}" data-field="expectedLifespan" bindinput="updateField" />
        </view>
      </view>

      <view class="field-grid">
        <view class="field">
          <view class="field__label">
            <image class="icon-xs" src="{{icons.wallet}}" mode="aspectFit" />
            <text>月度燃料（税前月收入）</text>
          </view>
          <view class="field__money">
            <text class="field__money-prefix">¥</text>
            <input class="field__input field__input--money" type="number" value="{{form.monthlySalary}}" data-field="monthlySalary" bindinput="updateField" />
          </view>
        </view>

        <view class="field">
          <view class="field__label">
            <image class="icon-xs" src="{{icons.trendingUp}}" mode="aspectFit" />
            <text>燃料到账日（发薪日）</text>
          </view>
          <input class="field__input" type="number" value="{{form.payDay}}" data-field="payDay" bindinput="updateField" />
        </view>
      </view>
    </view>

    <view class="settings-section settings-section--last">
      <pp-section-header title="航行排班计划（工作作息配置）" barTone="blue" />

      <view class="field">
        <view class="field__label">
          <image class="icon-xs" src="{{icons.calendarDays}}" mode="aspectFit" />
          <text>航行周期模式（每周休息制度）</text>
        </view>
        <view class="mode-grid">
          <view class="mode-grid__item {{form.workMode === 'double' ? 'mode-grid__item--active' : ''}}" data-value="double" bind:tap="chooseWorkMode">
            <text class="mode-grid__text">双休</text>
          </view>
          <view class="mode-grid__item {{form.workMode === 'single-sat' ? 'mode-grid__item--active' : ''}}" data-value="single-sat" bind:tap="chooseWorkMode">
            <text class="mode-grid__text">休六</text>
          </view>
          <view class="mode-grid__item {{form.workMode === 'single-sun' ? 'mode-grid__item--active' : ''}}" data-value="single-sun" bind:tap="chooseWorkMode">
            <text class="mode-grid__text">休日</text>
          </view>
          <view class="mode-grid__item {{form.workMode === 'big-small' ? 'mode-grid__item--active' : ''}}" data-value="big-small" bind:tap="chooseWorkMode">
            <text class="mode-grid__text">大小周</text>
          </view>
        </view>
      </view>

      <view class="switch-row" wx:if="{{form.workMode === 'big-small'}}">
        <text class="switch-row__label">本周是大周吗？</text>
        <view class="switch {{form.isCurrentBigWeek ? 'switch--active' : ''}}" bind:tap="toggleBigWeek">
          <view class="switch__thumb"></view>
        </view>
      </view>

      <view class="field-grid">
        <view class="field">
          <view class="field__label">
            <image class="icon-xs" src="{{icons.clock}}" mode="aspectFit" />
            <text>预计启航时间（上班时间）</text>
          </view>
          <picker mode="time" value="{{form.startTime}}" data-field="startTime" bindchange="updateField">
            <view class="field__picker">{{form.startTime}}</view>
          </picker>
        </view>

        <view class="field">
          <view class="field__label">
            <image class="icon-xs" src="{{icons.clock}}" mode="aspectFit" />
            <text>预计归港时间（下班时间）</text>
          </view>
          <picker mode="time" value="{{form.endTime}}" data-field="endTime" bindchange="updateField">
            <view class="field__picker">{{form.endTime}}</view>
          </picker>
        </view>
      </view>

      <view class="sub-card">
        <view class="switch-row switch-row--tight">
          <view class="field__label field__label--compact">
            <image class="icon-xs" src="{{icons.coffee}}" mode="aspectFit" />
            <text>午间补给时间（午休时间段）</text>
          </view>
          <view class="switch {{form.lunchBreakEnabled ? 'switch--active switch--active-emerald' : ''}}" bind:tap="toggleLunchBreak">
            <view class="switch__thumb"></view>
          </view>
        </view>

        <view class="field-grid" wx:if="{{form.lunchBreakEnabled}}">
          <view class="field field--sub">
            <view class="field__label">
              <image class="icon-xs" src="{{icons.clock}}" mode="aspectFit" />
              <text>补给开始（午休开始时间）</text>
            </view>
            <picker mode="time" value="{{form.lunchStartTime}}" data-field="lunchStartTime" bindchange="updateField">
              <view class="field__picker">{{form.lunchStartTime}}</view>
            </picker>
          </view>

          <view class="field field--sub">
            <view class="field__label">
              <image class="icon-xs" src="{{icons.clock}}" mode="aspectFit" />
              <text>补给结束（午休结束时间）</text>
            </view>
            <picker mode="time" value="{{form.lunchEndTime}}" data-field="lunchEndTime" bindchange="updateField">
              <view class="field__picker">{{form.lunchEndTime}}</view>
            </picker>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="save-bar">
    <view class="save-bar__button {{pressStates.save ? 'save-bar__button--pressed' : ''}}" bind:tap="pressSave">
      <image class="icon-sm" src="{{icons.checkCircle2}}" mode="aspectFit" />
      <text class="save-bar__text">保存档案</text>
    </view>
  </view>
</view>
