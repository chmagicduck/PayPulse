<view class="page-view community-page">
  <view class="community-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="community-nav__content">
      <view class="community-nav__button" bind:tap="handleBack">
        <image class="icon-lg" src="{{icons.arrowLeft}}" mode="aspectFit" />
      </view>
      <text class="community-nav__title">{{vm.title}}</text>
      <view class="community-nav__button">
        <image class="icon-lg" src="{{icons.share2}}" mode="aspectFit" />
      </view>
    </view>
  </view>

  <view class="community-main">
    <view class="hero-card">
      <view class="hero-card__badge">
        <image class="icon-xs" src="{{icons.star}}" mode="aspectFit" />
        <text class="hero-card__badge-text">{{vm.badge}}</text>
      </view>
      <text class="hero-card__title">{{vm.headline}}</text>
      <text class="hero-card__highlight">{{vm.highlight}}</text>
      <text class="hero-card__desc">{{vm.description}}</text>

      <view class="hero-stats">
        <block wx:for="{{vm.stats}}" wx:key="label">
          <view class="hero-stats__item">
            <view class="hero-stats__meta">
              <image class="icon-xs" src="{{index === 0 ? icons.users : index === 1 ? icons.messageSquare : icons.globe}}" mode="aspectFit" />
              <text class="hero-stats__label">{{item.label}}</text>
            </view>
            <text class="hero-stats__value">{{item.value}}</text>
          </view>
        </block>
      </view>
    </view>

    <view class="join-card">
      <view class="join-card__head">
        <image class="join-card__anchor" src="{{icons.anchorPair.staticSrc}}" mode="aspectFit" />
        <text class="join-card__title">深海避风港</text>
        <text class="join-card__subtitle">官方群入口</text>
      </view>

      <view class="join-card__button">
        <text class="join-card__button-text">立即加入微信群聊</text>
        <image class="icon-sm" src="{{icons.chevronRight}}" mode="aspectFit" />
      </view>

      <text class="join-card__note">点击主按钮仅保留静态查阅视觉，不接入真实入群流程。</text>
    </view>

    <view class="section-title">
      <view class="section-title__bar"></view>
      <text class="section-title__text">社群专属权益</text>
    </view>

    <view class="benefit-list">
      <block wx:for="{{benefits}}" wx:key="title">
        <view class="benefit-card">
          <view class="benefit-card__icon benefit-card__icon--{{item.tone}}">
            <image class="icon-md" src="{{item.iconSrc}}" mode="aspectFit" />
          </view>
          <view class="benefit-card__copy">
            <text class="benefit-card__title">{{item.title}}</text>
            <text class="benefit-card__desc">{{item.desc}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="fake-tabbar">
    <view class="fake-tabbar__item">领潮中心</view>
    <view class="fake-tabbar__item">洋流战报</view>
    <view class="fake-tabbar__item">动力舱</view>
    <view class="fake-tabbar__item fake-tabbar__item--active">个人基地</view>
  </view>
</view>
