<view class="pp-section-header {{showStackSubtitle ? 'pp-section-header--with-subtitle' : ''}} {{trimBottom ? 'pp-section-header--trim-bottom' : ''}}">
  <view class="pp-section-header__title-group">
    <view class="{{barClassName}}" wx:if="{{showBar}}"></view>
    <view class="pp-section-header__copy">
      <text class="pp-section-header__title">{{title}}</text>
      <text class="pp-section-header__subtitle" wx:if="{{showStackSubtitle}}">{{subtitle}}</text>
    </view>
  </view>

  <text class="pp-section-header__subtitle pp-section-header__subtitle--right" wx:if="{{showRightSubtitle}}">{{subtitle}}</text>

  <view class="pp-section-header__manage" wx:if="{{showManage}}" bind:tap="handleManageTap">
    <text class="{{manageClassName}}">{{manageText}}</text>
    <image class="pp-section-header__chevron" wx:if="{{showChevron}}" src="{{chevronSrc}}" mode="aspectFit" />
  </view>

  <text class="{{tagClassName}}" wx:if="{{showTag}}">{{tagText}}</text>
</view>
