<view class="pp-tab-bar" style="padding-bottom: {{safeAreaBottom}}px;">
  <view class="pp-tab-bar__inner">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="pp-tab-bar__item {{item.key === activeTab ? 'pp-tab-bar__item--active' : ''}}"
      data-key="{{item.key}}"
      data-url="{{item.url}}"
      bind:tap="onTabTap"
    >
      <image
        class="pp-tab-bar__icon {{item.key === activeTab ? 'pp-tab-bar__icon--active' : ''}}"
        src="{{item.key === activeTab ? item.activeIcon : item.icon}}"
        mode="aspectFit"
      />
      <text class="pp-tab-bar__label {{item.key === activeTab ? 'pp-tab-bar__label--active' : ''}}">{{item.label}}</text>
    </view>
  </view>
</view>
